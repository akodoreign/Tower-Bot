[
  {
    "name": "Sera Voss",
    "faction": "Iron Fang Consortium",
    "rank": "Senior Acquisitions Agent (field rank \u2014 reports directly to Serrik Dhal)",
    "species": "Half-Elf",
    "age": "34",
    "appearance": "Sharp cheekbones, iron-grey hair despite her age, always wears a long coat with too many pockets. Missing two fingers on her left hand \u2014 never explains how.",
    "location": "Crimson Alley, Markets Infinite (operates from a rented storage room behind a spice merchant)",
    "motivation": "Advancement. Sera wants Serrik Dhal's seat. She believes the Consortium wastes talent on loyalty and hoards opportunity at the top. She's building a private network of contacts independent of official channels.",
    "role": "Brokers relic acquisitions, manages field teams, occasionally handles \"disappearance\" contracts personally.",
    "secret": "",
    "relationships": "Uneasy respect from Wex (courier \u2014 owes her a favour). Genuine dislike of Dova (Glass Sigil \u2014 she thinks archivists are parasites). Complicated history with Aric Veyne.",
    "oracle_notes": "The Oracle would sense ambition so sharp it has become its own kind of blindness. Sera doesn't fear gods \u2014 she just hasn't met one yet.",
    "status": "alive",
    "revealed_secrets": [
      "Sera Voss, in her clandestine existence, serves as a secret informant to the Undercity's Resistance movement, working against the Iron Fang Consortium from within."
    ],
    "history": [
      "[2026-03-05] Entered roster from static file.",
      "[2026-03-10] New secret acquired.",
